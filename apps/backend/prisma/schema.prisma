generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CLIENT
  PROVIDER
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NOSHOW
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  name      String?
  role      Role      @default(CLIENT)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  ownedBusinesses Business[]    @relation("BusinessOwner")
  appointments    Appointment[] @relation("ClientAppointments")
  staffAssignments Appointment[] @relation("ProviderAssignments")

  @@map("users")
}

model Business {
  id           String    @id @default(uuid())
  name         String
  address      String
  description  String?
  openingHours Json?     @map("opening_hours")
  latitude     Float?
  longitude    Float?
  ownerId      String    @map("owner_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  // Relations
  owner    User      @relation("BusinessOwner", fields: [ownerId], references: [id])
  services Service[]

  @@map("businesses")
}

model Service {
  id         String    @id @default(uuid())
  name       String
  duration   Int // duration in minutes
  price      Decimal   @db.Decimal(10, 2)
  businessId String    @map("business_id")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  // Relations
  business     Business      @relation(fields: [businessId], references: [id])
  appointments Appointment[]

  @@map("services")
}

model Appointment {
  id         String            @id @default(uuid())
  status     AppointmentStatus @default(PENDING)
  startTime  DateTime          @map("start_time")
  endTime    DateTime          @map("end_time")
  clientId   String            @map("client_id")
  providerId String            @map("provider_id")
  serviceId  String            @map("service_id")
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")
  deletedAt  DateTime?         @map("deleted_at")

  // Relations
  client   User    @relation("ClientAppointments", fields: [clientId], references: [id])
  provider User    @relation("ProviderAssignments", fields: [providerId], references: [id])
  service  Service @relation(fields: [serviceId], references: [id])

  @@index([startTime])
  @@index([endTime])
  @@map("appointments")
}
